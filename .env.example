# API keys are NOT set here — they live in the Settings ⚙ panel
# (encrypted in your OS keychain via Electron safeStorage, or in
# localStorage when running as a web app) and travel as per-request
# X-LLM-Provider / X-LLM-Key headers. No key is ever persisted
# server-side.
#
# This file is only for optional backend tuning. All values have
# defaults — you can delete this file entirely.

# Server
HOST=0.0.0.0
PORT=8003

# Scraper concurrency — max sub-agents running in parallel per render
SCRAPE_CONCURRENCY=4

# Scrape cache TTL in seconds (per-URL extract cache; web data is fresh-sensitive)
SCRAPE_CACHE_TTL=900

# GPT-5.x reasoning effort for the orchestrator: none | low | medium | high
# (Only applies when provider=openai. Default 'none' = no thinking step.)
ORCHESTRATOR_REASONING_EFFORT=none
